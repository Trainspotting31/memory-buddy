{
  "name": "memory-buddy",
  "main": "src/index.ts",
  "compatibility_date": "2024-04-01",
  "node_compat": true,
  "d1_databases": [
    {
      "binding": "MEMORY_DB",
      "database_name": "agent-memory-db",
      "preview_database_id": ""
    }
  ],
  "vectorize": [
    {
      "binding": "MEMORY_VECTORIZE",
      "index_name": "agent-memory-index",
      "preview_index_id": ""
    }
  ],
  "ai": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT_DO",
        "class_name": "AgentDO"
      }
    ]
  },
  "vars": {
    "LLM_API_KEY": "",
    "LLM_API_BASE": "",
    "LLM_MODEL": "@cf/meta/llama-3.1-8b-instruct"
  }
}